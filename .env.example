# Fichier .env.example - Copier et renommer en .env.local

# ============================================
# DATABASE
# ============================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/dakar_jobs"

# ============================================
# AUTHENTIFICATION
# ============================================
# Générez une clé secrète sécurisée pour JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# NextAuth configuration (optionnel)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-change-this-in-production"

# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV="development"
# development, production, test

# ============================================
# OAUTH (Google Sign-In)
# ============================================
# Obtenez ces valeurs depuis https://console.cloud.google.com
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# API EXTERNE
# ============================================
# Exemple pour l'upload de fichiers
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# ============================================
# EMAIL (pour notifications)
# ============================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-app-password"
# ADMIN_EMAIL="admin@dakarcjobs.sn"

# ============================================
# ANALYTICS (optionnel)
# ============================================
# NEXT_PUBLIC_GOOGLE_ANALYTICS="G-XXXXXXXXXX"

# ============================================
# VARIABLES PUBLIQUES
# ============================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Dakar Jobs"
